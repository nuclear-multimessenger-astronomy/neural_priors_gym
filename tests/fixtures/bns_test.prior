chirp_mass = Uniform(minimum=1.0, maximum=1.4, name='chirp_mass', latex_label='$\\mathcal{M}$')
mass_ratio = Uniform(minimum=0.5, maximum=1.0, name='mass_ratio', latex_label='$q$')
luminosity_distance = PowerLaw(alpha=2, minimum=10, maximum=500, name='luminosity_distance', latex_label='$d_L$', unit='Mpc')
